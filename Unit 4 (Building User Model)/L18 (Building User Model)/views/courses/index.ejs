<h2>Courses Table</h2>
<table class="table">
  <thead>
    <tr>
      <th>Title</th>
      <th>Description</th>
    </tr>
  </thead>
  <tbody>
    <% courses.forEach(course => { %>
    <tr>
      <td>
        <%= course.title %>
      </td>
      <td>
        <%= course.description %>
      </td>
    </tr>
    <% }); %>
  </tbody>
</table>



<!-- Listing 18.8 (Listing all users in index.js)-->
<h2>Users Table</h2>
<table class="table">
 <thead>
 <tr>
 <th>Name</th>
 <th>Email</th>
 <th>Zip Code</th>
 </tr>
 </thead>
 <tbody>
 <% users.forEach(user => { %>
 <tr>
 <td><%= user.fullName %></td>
 <td><%= user.email %></td>
 <td><%= user.zipCode %></td>
 </tr>
 <% }); %>
 </tbody>
</table> 
